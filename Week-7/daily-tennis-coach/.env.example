# 데일리테니스 서버 환경변수 (매장 PC 로컬 운영판)
# 복사: cp .env.example .env
#
# 로컬 운영이라 환경변수는 거의 필요 없음. 기본값으로 그대로 동작한다.

# 서버 포트 (기본 3000)
PORT=3000

# Store token TTL (일 단위, 기본 2일)
# 매장 모니터에 표시되는 지속형 QR의 토큰 회전 주기
STORE_TOKEN_TTL_DAYS=2

# ffmpeg 실행 파일 경로
# - macOS Homebrew 기본: /opt/homebrew/bin/ffmpeg
# - 시스템 PATH에 ffmpeg가 있으면 그냥 'ffmpeg' (또는 빈칸)
FFMPEG_PATH=ffmpeg
