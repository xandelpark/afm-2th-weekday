# 로컬 개발용 환경변수 예시 (.env로 복사해서 사용)

# Supabase PostgreSQL pooler 연결 URL — 비밀번호는 URL 인코딩 필요
DATABASE_URL=postgresql://postgres.<PROJECT_REF>:<URL_ENCODED_PASSWORD>@aws-1-us-east-1.pooler.supabase.com:6543/postgres

# JWT 서명용 비밀키 (길고 랜덤하게. 노출 금지)
JWT_SECRET=change-me-to-a-long-random-string

# 로컬 서버 포트
PORT=3006
